rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isManager() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'manager');
    }

    function isPublicTournament(tournamentId) {
      return exists(/databases/$(database)/documents/tournaments/$(tournamentId)) &&
        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.status in ['active', 'completed'];
    }

    // ── Users ──
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Athletes ──
    match /athletes/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManager();
    }

    // ── Teams ──
    match /teams/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManager();
    }

    // ── Sports ──
    match /sports/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManager();
    }

    // ── Tournaments ──
    match /tournaments/{docId} {
      allow read: if isAuthenticated() || resource.data.status in ['active', 'completed'];
      allow create, update, delete: if isManager();
    }

    // ── Matches ──
    match /matches/{docId} {
      allow read: if isAuthenticated() || isPublicTournament(resource.data.tournamentId);
      allow create, update, delete: if isManager();
    }

    // ── Schedules ──
    match /schedules/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManager();
    }

    // ── Announcements ──
    match /announcements/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManager();
    }

    // ── Venues ──
    match /venues/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManager();
    }

    // ── Leaderboard ──
    match /leaderboard_entries/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManager();
    }

    // ── Settings ──
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Activity Log ──
    match /activity_log/{docId} {
      allow read: if isAuthenticated();
      allow create: if isManager();
      allow update, delete: if isAdmin();
    }
  }
}
